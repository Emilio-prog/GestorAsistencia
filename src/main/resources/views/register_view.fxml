<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dam.gestorasistencia.controller.RegisterController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <Label text="Registrar Nuevo Usuario">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <TextField fx:id="txtNombre" promptText="Nombre completo" maxWidth="300" />
    <TextField fx:id="txtEmail" promptText="Correo electrónico" maxWidth="300" />
    <PasswordField fx:id="txtPassword" promptText="Contraseña" maxWidth="300" />

    <Label text="Rol:" />
    <ComboBox fx:id="cbRol" prefWidth="300.0" />

    <Button text="Guardar Usuario" onAction="#onRegistrar" defaultButton="true" style="-fx-background-color: #28a745; -fx-text-fill: white;" maxWidth="300"/>
    <Button text="Cancelar" onAction="#onVolver" cancelButton="true" maxWidth="300"/>
</VBox>