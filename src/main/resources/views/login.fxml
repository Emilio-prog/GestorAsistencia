<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.dam.gestorasistencia.controller.LoginController"
           styleClass="login-split-root"
           prefHeight="600.0" prefWidth="950.0">

    <!-- CAPA 1: Fondo dividido (azul izquierda + gris derecha) -->
    <HBox>
        <!-- Panel azul con branding -->
        <VBox styleClass="login-brand-panel" alignment="CENTER" spacing="16"
              prefWidth="520" minWidth="520" maxWidth="520">

            <!-- Icono birrete -->
            <StackPane styleClass="login-brand-icon-ring" alignment="CENTER">
                <FontIcon iconLiteral="mdmz-school" styleClass="login-brand-icon"/>
            </StackPane>

            <Region prefHeight="4"/>

            <!-- Titulo de la app -->
            <Label text="Gestor de" styleClass="login-brand-title"/>
            <Label text="Asistencia" styleClass="login-brand-title"
                   style="-fx-padding: -12 0 0 0;"/>

            <!-- Tagline -->
            <Label text="Control de asistencia inteligente"
                   styleClass="login-brand-subtitle"/>

            <Region prefHeight="16"/>

            <!-- Feature pills -->
            <HBox alignment="CENTER" spacing="10">
                <HBox styleClass="login-brand-pill" alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="mdal-flash_on" styleClass="login-pill-icon"/>
                    <Label text="R&#xe1;pido" styleClass="login-pill-text"/>
                </HBox>
                <HBox styleClass="login-brand-pill" alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="mdal-check_circle" styleClass="login-pill-icon"/>
                    <Label text="Seguro" styleClass="login-pill-text"/>
                </HBox>
                <HBox styleClass="login-brand-pill" alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="mdal-apps" styleClass="login-pill-icon"/>
                    <Label text="Simple" styleClass="login-pill-text"/>
                </HBox>
            </HBox>
        </VBox>

        <!-- Fondo gris derecho -->
        <Region HBox.hgrow="ALWAYS" styleClass="login-form-panel"/>
    </HBox>

    <!-- CAPA 2: Tarjeta flotante SUPERPUESTA sobre ambos paneles -->
    <VBox styleClass="login-card" alignment="CENTER_LEFT"
          StackPane.alignment="CENTER_RIGHT"
          prefWidth="430" maxWidth="430">
        <StackPane.margin>
            <Insets right="50" top="40" bottom="40"/>
        </StackPane.margin>

        <!-- Titulo -->
        <Label text="Bienvenido de nuevo" styleClass="login-form-title"/>

        <!-- Subtitulo -->
        <Label text="Introduce tus credenciales para acceder"
               styleClass="text-secondary"/>

        <Region prefHeight="22"/>

        <!-- Campo Email: solo placeholder, sin label separado -->
        <HBox styleClass="input-group" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="mdal-email" styleClass="input-group-icon"/>
            <TextField fx:id="txtEmail"
                       promptText="Correo electr&#xf3;nico"
                       HBox.hgrow="ALWAYS"
                       styleClass="input-group-field"/>
        </HBox>

        <Region prefHeight="16"/>

        <!-- Campo Contrasena: solo placeholder, sin label separado -->
        <HBox styleClass="input-group" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="mdal-lock" styleClass="input-group-icon"/>
            <PasswordField fx:id="txtPassword"
                           promptText="Contrase&#xf1;a"
                           HBox.hgrow="ALWAYS"
                           styleClass="input-group-field"
                           onAction="#onLogin"/>
            <FontIcon iconLiteral="mdmz-visibility_off" styleClass="input-group-icon-right"/>
        </HBox>

        <Region prefHeight="22"/>

        <!-- Boton Iniciar Sesion -->
        <Button text="Iniciar Sesi&#xf3;n  &#x2192;"
                onAction="#onLogin"
                defaultButton="true"
                maxWidth="Infinity"
                styleClass="btn-primary, btn-lg"/>

        <Region prefHeight="10"/>

        <!-- Link decorativo -->
        <HBox alignment="CENTER">
            <Hyperlink text="&#xbf;Olvidaste tu contrase&#xf1;a?" styleClass="login-link"/>
        </HBox>

    </VBox>

</StackPane>
