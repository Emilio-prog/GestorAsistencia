<?xml version="1.0" encoding="UTF-8"?>

<!--
  Vista principal del sistema.
  Incluye panel de asistencia, sección de informes y zona de configuración.
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dam.gestorasistencia.controller.MainController"
      styleClass="dashboard-root"
      prefHeight="700.0" prefWidth="1120.0">

    <VBox styleClass="sidebar" prefWidth="260" minWidth="260" maxWidth="260">
        <VBox styleClass="sidebar-logo-area" alignment="CENTER" spacing="0">
            <padding><Insets top="28" right="20" bottom="24" left="20"/></padding>
            <StackPane styleClass="sidebar-logo-gear" alignment="CENTER">
                <FontIcon iconLiteral="mdmz-settings" styleClass="sidebar-gear-icon"/>
                <Label text="G" styleClass="sidebar-logo-letter"/>
            </StackPane>
        </VBox>

        <Separator styleClass="sidebar-separator"/>

        <VBox styleClass="sidebar-nav" spacing="4">
            <padding><Insets top="16" right="14" bottom="8" left="14"/></padding>

            <HBox fx:id="navPanelControl" styleClass="sidebar-item, sidebar-item-active" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#mostrarPanelControl">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-dashboard" styleClass="sidebar-item-icon"/>
                <Label text="Panel de Control" styleClass="sidebar-item-text"/>
            </HBox>

            <HBox fx:id="navInformes" styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#mostrarSeccionInformes">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-assessment" styleClass="sidebar-item-icon"/>
                <Label text="Informes" styleClass="sidebar-item-text"/>
            </HBox>

            <HBox fx:id="navConfiguracion" styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#mostrarSeccionConfiguracion">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdmz-settings" styleClass="sidebar-item-icon"/>
                <Label text="Configuración" styleClass="sidebar-item-text"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="4">
            <padding><Insets top="8" right="14" bottom="20" left="14"/></padding>
            <Button text="Salir" onAction="#onCerrarSesion"
                    mnemonicParsing="false"
                    styleClass="sidebar-btn-salir" maxWidth="Infinity"
                    alignment="CENTER_LEFT" graphicTextGap="12">
                <graphic>
                    <FontIcon iconLiteral="mdal-exit_to_app" styleClass="sidebar-item-icon"/>
                </graphic>
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
            </Button>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" styleClass="dashboard-main">
        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

        <VBox spacing="4">
            <Label fx:id="lblPageTitle" text="Panel de Control" styleClass="dashboard-page-title"/>
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Home" styleClass="breadcrumb-link"/>
                <Label text=">" styleClass="breadcrumb-separator"/>
                <Label fx:id="lblBreadcrumb" text="Gesti&#xf3;n de asistencia diaria" styleClass="breadcrumb-current"/>
            </HBox>
        </VBox>

        <Region prefHeight="16"/>

        <StackPane VBox.vgrow="ALWAYS">
            <VBox fx:id="vistaAsistencia" styleClass="dashboard-card" VBox.vgrow="ALWAYS" spacing="0">
                <Label text="Gesti&#xf3;n de asistencia diaria" styleClass="dashboard-section-title">
                    <padding><Insets top="16" right="20" bottom="0" left="20"/></padding>
                </Label>

                <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="15">
                    <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="mdal-calendar_today" styleClass="filter-icon"/>
                        <DatePicker fx:id="dpFecha" onAction="#cargarAlumnos"
                                    promptText="DD/MM/YYYY"
                                    prefWidth="170" minWidth="170"/>
                    </HBox>

                    <ComboBox fx:id="cbAsignatura" onAction="#cargarAlumnos"
                              promptText="Selecciona Asignatura"
                              prefWidth="250" minWidth="250"/>

                    <ComboBox fx:id="cbGrupo" onAction="#cargarAlumnos"
                              prefWidth="110" minWidth="110"/>

                    <Button text="Refrescar" onAction="#cargarAlumnos"
                            mnemonicParsing="false"
                            minWidth="-Infinity"
                            styleClass="btn-primary, btn-sm, btn-icon">
                        <graphic>
                            <FontIcon iconLiteral="mdmz-refresh" styleClass="icon-white, icon-sm"/>
                        </graphic>
                    </Button>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="btnAdmin" text="Registrar Profesor"
                                onAction="#irAdmin" visible="false"
                                minWidth="-Infinity"
                                styleClass="btn-warning, btn-sm, btn-icon">
                            <graphic>
                                <FontIcon iconLiteral="mdal-admin_panel_settings" styleClass="icon-white, icon-sm"/>
                            </graphic>
                        </Button>

                        <Button fx:id="btnAddAlumno" text="Alumno"
                                onAction="#onAddAlumno" visible="false"
                                minWidth="-Infinity"
                                styleClass="btn-success, btn-sm, btn-icon">
                            <graphic>
                                <FontIcon iconLiteral="mdmz-person_add" styleClass="icon-white, icon-sm"/>
                            </graphic>
                        </Button>

                        <Button fx:id="btnDelAlumno" text="Eliminar"
                                onAction="#onDeleteAlumno" visible="false"
                                minWidth="-Infinity"
                                styleClass="btn-danger, btn-sm, btn-icon">
                            <graphic>
                                <FontIcon iconLiteral="mdal-delete_outline" styleClass="icon-white, icon-sm"/>
                            </graphic>
                        </Button>
                    </HBox>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" styleClass="dashboard-table-container">
                    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

                    <TableView fx:id="tblAlumnos" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNombre" prefWidth="220" text="Nombre"/>
                            <TableColumn fx:id="colApellidos" prefWidth="280" text="Apellidos"/>
                            <TableColumn fx:id="colEstado" prefWidth="200" text="Estado"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <HBox styleClass="dashboard-footer" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                    <Label fx:id="lblInfo" text="Listo" styleClass="footer-info-text"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Todos Presentes" onAction="#onMarcarTodosPresentes" styleClass="btn-outline-primary, btn-sm, btn-icon">
                        <graphic><FontIcon iconLiteral="mdal-check_circle_outline" styleClass="icon-primary, icon-sm"/></graphic>
                    </Button>
                    <Button text="Guardar Asistencia" onAction="#onGuardar" defaultButton="true" mnemonicParsing="false" styleClass="btn-primary, btn-sm, btn-icon">
                        <graphic><FontIcon iconLiteral="mdmz-save" styleClass="icon-white, icon-sm"/></graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox fx:id="vistaConfiguracion" styleClass="dashboard-card settings-view" visible="false" managed="false" spacing="22" VBox.vgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Configuración" styleClass="dashboard-section-title"/>

                <HBox spacing="16">
                    <VBox styleClass="settings-card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="Apariencia" styleClass="settings-card-title"/>
                        <Label text="Tema" styleClass="settings-label"/>
                        <HBox spacing="8" styleClass="theme-selector">
                            <ToggleButton fx:id="btnTemaLight" text="Light" onAction="#onTemaLight" styleClass="theme-toggle"/>
                            <ToggleButton fx:id="btnTemaDark" text="Dark" onAction="#onTemaDark" styleClass="theme-toggle"/>
                            <ToggleButton fx:id="btnTemaSystem" text="System" onAction="#onTemaSystem" styleClass="theme-toggle"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="settings-card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="Datos" styleClass="settings-card-title"/>
                        <Label text="Exportar información actual" styleClass="settings-label"/>
                        <HBox spacing="10">
                            <Button text="Descargar JSON" onAction="#exportarDatosJson" styleClass="btn-outline-primary"/>
                            <Button text="Descargar PDF" onAction="#exportarDatosPdf" styleClass="btn-outline-primary"/>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox styleClass="settings-card" spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="Acerca de la aplicación" styleClass="settings-card-title"/>
                    <Label wrapText="true" text="Gestor de Asistencia permite administrar la asistencia diaria, clases e informes. Desde esta sección puedes personalizar la apariencia y exportar una copia de los datos solicitados (usuario en sesión, alumnos ordenados por clase y asignaturas)." styleClass="settings-about-text"/>
                </VBox>
            </VBox>

            <VBox fx:id="vistaInformes" styleClass="dashboard-card" visible="false" managed="false" spacing="16" VBox.vgrow="ALWAYS">
                <Label text="Informes y Estad&#xed;sticas" styleClass="dashboard-section-title">
                    <padding><Insets top="16" right="20" bottom="0" left="20"/></padding>
                </Label>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
                    <Label fx:id="lblTotalPresentes" text="Presentes: 0"/>
                    <Label fx:id="lblTotalFaltas" text="Faltas: 0"/>
                    <Label fx:id="lblTotalRetrasos" text="Retrasos: 0"/>
                    <Label fx:id="lblTotalJustificadas" text="Justificadas: 0"/>
                </HBox>

                <PieChart fx:id="chartEstadisticas" title="Resumen de Asistencia" VBox.vgrow="ALWAYS">
                    <padding><Insets top="0" right="20" bottom="20" left="20"/></padding>
                </PieChart>
            </VBox>
        </StackPane>
    </VBox>
</HBox>
