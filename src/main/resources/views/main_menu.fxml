<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Raiz: fondo suave con la card central flotando -->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.dam.gestorasistencia.controller.MainController"
           styleClass="dashboard-root"
           prefHeight="680.0" prefWidth="1050.0">

    <!-- Card principal que contiene todo -->
    <VBox styleClass="dashboard-card" spacing="0"
          StackPane.alignment="CENTER">
        <padding>
            <Insets bottom="0" left="0" right="0" top="0" />
        </padding>

        <!-- HEADER -->
        <HBox styleClass="dashboard-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets bottom="16" left="28" right="28" top="16" />
            </padding>

            <!-- Icono + Titulo -->
            <StackPane styleClass="dashboard-header-icon-bg" alignment="CENTER">
                <FontIcon iconLiteral="mdal-fact_check" styleClass="icon-primary, icon-md"/>
            </StackPane>

            <VBox spacing="0">
                <Label text="Panel de Control" styleClass="title-lg"/>
                <Label text="Gestion de asistencia diaria" styleClass="text-muted"/>
            </VBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Botones admin (visibles solo para ADMIN) -->
            <Button fx:id="btnAdmin" text="Registrar Profesor"
                    onAction="#irAdmin" visible="false"
                    styleClass="btn-warning, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdal-admin_panel_settings" styleClass="icon-white, icon-sm"/>
                </graphic>
            </Button>

            <!-- Cerrar sesion -->
            <Button text="Salir" onAction="#onCerrarSesion"
                    mnemonicParsing="false"
                    styleClass="btn-ghost, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdal-exit_to_app" styleClass="icon-muted, icon-sm"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Linea separadora -->
        <Separator/>

        <!-- BARRA DE FILTROS -->
        <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets bottom="14" left="28" right="28" top="14" />
            </padding>

            <!-- Fecha -->
            <FontIcon iconLiteral="mdal-calendar_today" styleClass="icon-muted, icon-sm"/>
            <DatePicker fx:id="dpFecha" onAction="#cargarAlumnos" prefWidth="140.0"/>

            <!-- Asignatura -->
            <FontIcon iconLiteral="mdmz-menu_book" styleClass="icon-muted, icon-sm"/>
            <ComboBox fx:id="cbAsignatura" onAction="#cargarAlumnos" prefWidth="200.0"/>

            <!-- Grupo -->
            <FontIcon iconLiteral="mdal-groups" styleClass="icon-muted, icon-sm"/>
            <ComboBox fx:id="cbGrupo" onAction="#cargarAlumnos" prefWidth="110.0"/>

            <!-- Refrescar -->
            <Button text="Refrescar" onAction="#cargarAlumnos"
                    mnemonicParsing="false"
                    styleClass="btn-outline-primary, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdmz-refresh" styleClass="icon-primary, icon-sm"/>
                </graphic>
            </Button>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Botones admin compactos -->
            <Button fx:id="btnAddAlumno" text="Alumno"
                    onAction="#onAddAlumno" visible="false"
                    styleClass="btn-success, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdmz-person_add" styleClass="icon-white, icon-sm"/>
                </graphic>
            </Button>

            <Button fx:id="btnDelAlumno" text="Eliminar"
                    onAction="#onDeleteAlumno" visible="false"
                    styleClass="btn-danger, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdal-delete_outline" styleClass="icon-white, icon-sm"/>
                </graphic>
            </Button>
        </HBox>

        <!-- TABLA DE ALUMNOS -->
        <VBox VBox.vgrow="ALWAYS" styleClass="dashboard-table-container">
            <padding>
                <Insets bottom="0" left="28" right="28" top="8" />
            </padding>

            <TableView fx:id="tblAlumnos" VBox.vgrow="ALWAYS" styleClass="dashboard-table">
                <columns>
                    <TableColumn fx:id="colNombre" prefWidth="200.0" text="Nombre"/>
                    <TableColumn fx:id="colApellidos" prefWidth="250.0" text="Apellidos"/>
                    <TableColumn fx:id="colEstado" prefWidth="200.0" text="Estado"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FOOTER -->
        <HBox styleClass="dashboard-footer" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets bottom="18" left="28" right="28" top="14" />
            </padding>

            <!-- Info label -->
            <FontIcon iconLiteral="mdal-info" styleClass="icon-muted, icon-sm"/>
            <Label fx:id="lblInfo" text="Listo" styleClass="text-secondary"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Estadisticas -->
            <Button text="Estadisticas" onAction="#verEstadisticas"
                    styleClass="btn-outline-primary, btn-sm, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdmz-pie_chart" styleClass="icon-primary, icon-sm"/>
                </graphic>
            </Button>

            <!-- Todos Presentes -->
            <Button text="Todos Presentes" onAction="#onMarcarTodosPresentes"
                    styleClass="btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdal-check_circle_outline" styleClass="icon-success, icon-sm"/>
                </graphic>
            </Button>

            <!-- Guardar Asistencia -->
            <Button text="Guardar Asistencia" onAction="#onGuardar"
                    defaultButton="true" mnemonicParsing="false"
                    styleClass="btn-primary, btn-lg, btn-icon">
                <graphic>
                    <FontIcon iconLiteral="mdmz-save" styleClass="icon-white, icon-md"/>
                </graphic>
            </Button>
        </HBox>

    </VBox>
</StackPane>
