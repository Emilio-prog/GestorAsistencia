<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Raiz: layout horizontal sidebar + contenido -->
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dam.gestorasistencia.controller.MainController"
      styleClass="dashboard-root"
      prefHeight="700.0" prefWidth="1120.0">

    <!-- SIDEBAR -->
    <VBox styleClass="sidebar" prefWidth="260" minWidth="260" maxWidth="260">

        <!-- Logo: engranaje grande centrado con G -->
        <VBox styleClass="sidebar-logo-area" alignment="CENTER" spacing="0">
            <padding><Insets top="28" right="20" bottom="24" left="20"/></padding>
            <StackPane styleClass="sidebar-logo-gear" alignment="CENTER">
                <FontIcon iconLiteral="mdmz-settings" styleClass="sidebar-gear-icon"/>
                <Label text="G" styleClass="sidebar-logo-letter"/>
            </StackPane>
        </VBox>

        <!-- Separador bajo logo -->
        <Separator styleClass="sidebar-separator"/>

        <!-- Menu de navegacion principal -->
        <VBox styleClass="sidebar-nav" spacing="4">
            <padding><Insets top="16" right="14" bottom="8" left="14"/></padding>

            <!-- Item activo: Panel de Control -->
            <HBox styleClass="sidebar-item, sidebar-item-active" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-dashboard" styleClass="sidebar-item-icon"/>
                <Label text="Panel de Control" styleClass="sidebar-item-text"/>
            </HBox>

            <!-- Item: Clases -->
            <HBox styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-class" styleClass="sidebar-item-icon"/>
                <Label text="Clases" styleClass="sidebar-item-text"/>
            </HBox>

            <!-- Item: Alumnos -->
            <HBox styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-groups" styleClass="sidebar-item-icon"/>
                <Label text="Alumnos" styleClass="sidebar-item-text"/>
            </HBox>

            <!-- Item: Informes -->
            <HBox styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdal-assessment" styleClass="sidebar-item-icon"/>
                <Label text="Informes" styleClass="sidebar-item-text"/>
            </HBox>
        </VBox>

        <!-- Spacer: empuja Configuracion y Salir al fondo -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Zona inferior: Configuracion + Salir -->
        <VBox spacing="4">
            <padding><Insets top="8" right="14" bottom="20" left="14"/></padding>

            <!-- Configuracion -->
            <HBox styleClass="sidebar-item" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
                <FontIcon iconLiteral="mdmz-settings" styleClass="sidebar-item-icon"/>
                <Label text="Configuraci&#xf3;n" styleClass="sidebar-item-text"/>
            </HBox>

            <!-- Salir -->
            <Button text="Salir" onAction="#onCerrarSesion"
                    mnemonicParsing="false"
                    styleClass="sidebar-btn-salir" maxWidth="Infinity"
                    alignment="CENTER_LEFT" graphicTextGap="12">
                <graphic>
                    <FontIcon iconLiteral="mdal-exit_to_app" styleClass="sidebar-item-icon"/>
                </graphic>
                <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
            </Button>
        </VBox>
    </VBox>

    <!-- AREA DE CONTENIDO PRINCIPAL -->
    <VBox HBox.hgrow="ALWAYS" styleClass="dashboard-main">
        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

        <!-- Header: Titulo + breadcrumbs -->
        <VBox spacing="4">
            <Label text="Panel de Control" styleClass="dashboard-page-title"/>
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Home" styleClass="breadcrumb-link"/>
                <Label text="&gt;" styleClass="breadcrumb-separator"/>
                <Label text="Gesti&#xf3;n de asistencia diaria" styleClass="breadcrumb-current"/>
            </HBox>
        </VBox>

        <Region prefHeight="16"/>

        <!-- Subtitulo de seccion -->
        <Label text="Gesti&#xf3;n de asistencia diaria" styleClass="dashboard-section-title"/>

        <Region prefHeight="12"/>

        <!-- CONTENEDOR BLANCO (card principal) -->
        <VBox styleClass="dashboard-card" VBox.vgrow="ALWAYS" spacing="0">

            <!-- BARRA DE FILTROS -->
            <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="10">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

                <!-- Fecha -->
                <FontIcon iconLiteral="mdal-calendar_today" styleClass="filter-icon"/>
                <DatePicker fx:id="dpFecha" onAction="#cargarAlumnos" prefWidth="148"/>

                <!-- Asignatura -->
                <ComboBox fx:id="cbAsignatura" onAction="#cargarAlumnos" prefWidth="200"/>

                <!-- Grupo -->
                <ComboBox fx:id="cbGrupo" onAction="#cargarAlumnos" prefWidth="100"/>

                <!-- Refrescar -->
                <Button text="Refrescar" onAction="#cargarAlumnos"
                        mnemonicParsing="false"
                        styleClass="btn-primary, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdmz-refresh" styleClass="icon-white, icon-sm"/>
                    </graphic>
                </Button>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Botones admin (ocultos por defecto) -->
                <Button fx:id="btnAdmin" text="Registrar Profesor"
                        onAction="#irAdmin" visible="false"
                        styleClass="btn-warning, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdal-admin_panel_settings" styleClass="icon-white, icon-sm"/>
                    </graphic>
                </Button>

                <Button fx:id="btnAddAlumno" text="Alumno"
                        onAction="#onAddAlumno" visible="false"
                        styleClass="btn-success, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdmz-person_add" styleClass="icon-white, icon-sm"/>
                    </graphic>
                </Button>

                <Button fx:id="btnDelAlumno" text="Eliminar"
                        onAction="#onDeleteAlumno" visible="false"
                        styleClass="btn-danger, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdal-delete_outline" styleClass="icon-white, icon-sm"/>
                    </graphic>
                </Button>
            </HBox>

            <!-- TABLA DE ALUMNOS -->
            <VBox VBox.vgrow="ALWAYS" styleClass="dashboard-table-container">
                <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

                <TableView fx:id="tblAlumnos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="220" text="Nombre"/>
                        <TableColumn fx:id="colApellidos" prefWidth="280" text="Apellidos"/>
                        <TableColumn fx:id="colEstado" prefWidth="200" text="Estado"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- FOOTER -->
            <HBox styleClass="dashboard-footer" alignment="CENTER_LEFT" spacing="10">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

                <!-- Info -->
                <Label fx:id="lblInfo" text="Listo" styleClass="footer-info-text"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Estadisticas -->
                <Button text="Estad&#xed;sticas" onAction="#verEstadisticas"
                        styleClass="btn-outline-primary, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdmz-pie_chart" styleClass="icon-primary, icon-sm"/>
                    </graphic>
                </Button>

                <!-- Todos Presentes -->
                <Button text="Todos Presentes" onAction="#onMarcarTodosPresentes"
                        styleClass="btn-outline-primary, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdal-check_circle_outline" styleClass="icon-primary, icon-sm"/>
                    </graphic>
                </Button>

                <!-- Guardar Asistencia -->
                <Button text="Guardar Asistencia" onAction="#onGuardar"
                        defaultButton="true" mnemonicParsing="false"
                        styleClass="btn-primary, btn-sm, btn-icon">
                    <graphic>
                        <FontIcon iconLiteral="mdmz-save" styleClass="icon-white, icon-sm"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>
</HBox>
