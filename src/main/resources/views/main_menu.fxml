<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dam.gestorasistencia.controller.MainController">

    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="Panel del Profesor">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>

                        <Button text="📊 Ver Estadísticas" onAction="#verEstadisticas" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-weight: bold;"/>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button fx:id="btnAddAlumno" text="+ Alumno" onAction="#onAddAlumno" visible="false" style="-fx-background-color: #28a745; -fx-text-fill: white;"/>
                                <Button fx:id="btnDelAlumno" text="- Eliminar" onAction="#onDeleteAlumno" visible="false" style="-fx-background-color: #dc3545; -fx-text-fill: white;"/>

                                <Button fx:id="btnAdmin" onAction="#irAdmin" style="-fx-background-color: #ffc107; -fx-text-fill: black; -fx-font-weight: bold;" text="Registrar Profesor" visible="false" />

                                <Button mnemonicParsing="false" onAction="#onCerrarSesion" text="Cerrar Sesión" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f0f0f0; -fx-background-radius: 5;">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="Fecha:" />
                        <DatePicker fx:id="dpFecha" onAction="#cargarAlumnos" prefWidth="120.0" />

                        <Label text="Asignatura:" />
                        <ComboBox fx:id="cbAsignatura" onAction="#cargarAlumnos" prefWidth="200.0" />

                        <Label text="Grupo:" />
                        <ComboBox fx:id="cbGrupo" onAction="#cargarAlumnos" prefWidth="100.0" />

                        <Button mnemonicParsing="false" onAction="#cargarAlumnos" text="Refrescar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tblAlumnos" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="200.0" text="Nombre" />
                <TableColumn fx:id="colApellidos" prefWidth="250.0" text="Apellidos" />
                <TableColumn fx:id="colEstado" prefWidth="200.0" text="Estado (Click para editar)" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Label fx:id="lblInfo" text="Listo" textFill="#666666" />
                <Button text="Todos Presentes" onAction="#onMarcarTodosPresentes" />
                <Button defaultButton="true" mnemonicParsing="false" onAction="#onGuardar" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="GUARDAR ASISTENCIA" />
            </children>
        </HBox>
    </bottom>

</BorderPane>