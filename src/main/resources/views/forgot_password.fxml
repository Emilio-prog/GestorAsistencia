<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.dam.gestorasistencia.controller.ForgotPasswordController"
           styleClass="login-split-root"
           prefHeight="600.0" prefWidth="950.0">

    <HBox>
        <VBox styleClass="recovery-brand-panel" alignment="CENTER" spacing="16"
              prefWidth="520" minWidth="520" maxWidth="520">

            <StackPane styleClass="login-brand-icon-ring" alignment="CENTER">
                <FontIcon iconLiteral="mdal-lock_open" styleClass="login-brand-icon"/>
            </StackPane>

            <Region prefHeight="4"/>

            <Label text="Recuperaci&#xf3;n" styleClass="login-brand-title"/>

            <Label text="Gesti&#xf3;n de Asistencia IES"
                   styleClass="login-brand-subtitle"/>

            <Region prefHeight="16"/>

            <HBox alignment="CENTER" spacing="10">
                <HBox styleClass="login-brand-pill" alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="mdal-email" styleClass="login-pill-icon"/>
                    <Label text="Comprueba tu email" styleClass="login-pill-text"/>
                </HBox>
                <HBox styleClass="login-brand-pill" alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="mdal-verified_user" styleClass="login-pill-icon"/>
                    <Label text="Contrase&#xf1;a segura" styleClass="login-pill-text"/>
                </HBox>
            </HBox>
        </VBox>

        <Region HBox.hgrow="ALWAYS" styleClass="login-form-panel"/>
    </HBox>

    <VBox styleClass="login-card" alignment="CENTER_LEFT"
          StackPane.alignment="CENTER_RIGHT"
          prefWidth="430" maxWidth="430">
        <StackPane.margin>
            <Insets right="50" top="40" bottom="40"/>
        </StackPane.margin>

        <Label text="&#xbf;Olvidaste tu contrase&#xf1;a?" styleClass="login-form-title"/>

        <Label text="No te preocupes. Introduce tu email y te enviaremos las instrucciones."
               styleClass="text-secondary" wrapText="true"/>

        <Region prefHeight="24"/>

        <Label text="CORREO ELECTR&#xd3;NICO" styleClass="input-label"/>

        <HBox styleClass="input-group" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="mdal-email" styleClass="input-group-icon"/>
            <TextField fx:id="txtRecoveryEmail"
                       promptText="ejemplo@ies.edu"
                       HBox.hgrow="ALWAYS"
                       styleClass="input-group-field"
                       onAction="#onSendInstructions"/>
        </HBox>

        <Region prefHeight="22"/>

        <Button text="&#x2708; Enviar instrucciones"
                onAction="#onSendInstructions"
                defaultButton="true"
                maxWidth="Infinity"
                styleClass="btn-primary, btn-lg"/>

        <Region prefHeight="10"/>

        <HBox alignment="CENTER">
            <Hyperlink text="&#x2190; Volver al inicio de sesi&#xf3;n"
                       styleClass="login-link"
                       onAction="#onBackToLogin"/>
        </HBox>

    </VBox>

</StackPane>
